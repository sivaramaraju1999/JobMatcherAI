# Environment variables for Job Matcher AI
# Copy this file to .env and fill in your actual values

# Telegram Bot Configuration (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# NVIDIA NIM Configuration (for LLM-powered resume tailoring and matching)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here
# Optional: specify model to use (default: nemotron-3-8b-chat)
NVIDIA_NIM_MODEL=nemotron-3-8b-chat

# Groq API Key (if using Groq for other LLM tasks)
GROK_API_KEY=your_groq_api_key_here

# Job Platform API Keys (if needed - some work without keys)
NOKRI_API_KEY=your_naukri_api_key_here
LINKEDIN_API_KEY=your_linkedin_api_key_here
INDEED_API_KEY=your_indeed_api_key_here

# LLM API Keys (for resume tailoring - alternative to NVIDIA NIM)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Resume Configuration
BASE_RESUME_PATH=./resumes/base_resume.txt
# OR
BASE_RESUME_TEXT=Please provide your base resume text here or specify a file path

# Experience & Preferences
TARGET_EXPERIENCE_YEARS=3
TARGET_LOCATIONS=Hyderabad,Remote,Hybrid
TARGET_ROLES=Senior SDET,Software Quality Engineer,Test Automation Engineer,QA Framework Architect,Automation Test Engineer,QA Lead

# Match Thresholds
INITIAL_MATCH_THRESHOLD=60
TARGET_MATCH_THRESHOLD=95

# Salary Preferences (in LPA - Lakhs Per Annum)
MIN_EXPECTED_SALARY_LPA=7
MAX_EXPECTED_SALARY_LPA=14